      "type": "custom",
      "format": "в”Ң{$1}пҶ’{$1}в”җ",
      "outputColor": "90"
    },
    {
      "type": "title",
      "format": "{#31}пҖ• {user-name-colored}{at-symbol-colored}{host-name-colored}"
    },
    {
      "type": "custom",
      "format": "в””{$1}пҶ’{$1}в”ҳ",
      "outputColor": "90"
    },
    {
