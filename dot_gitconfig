[core]
    pager = delta
    editor = nvim

[color]
    status = auto
    branch = auto
    interactive = auto
    diff = auto

[alias]
    st = status
    # Amend last commit without modifying commit message
    amend = "!git log -n 1 --pretty=tformat:%s%n%n%b | git commit -F - --amend"

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    dark = true
    line-numbers = true

[merge]
    ff = true

[rebase]
    autostash = true
    autosquash = true
